export default async (req) => {
  try {
    const { image } = await req.json();
    
    if (!image) {
      return new Response(JSON.stringify({ error: "No image provided" }), {
        status: 400,
        headers: { "Content-Type": "application/json" }
      });
    }

    const startResponse = await fetch("https://api.replicate.com/v1/predictions", {
      method: "POST",
      headers: {
        "Authorization": `Token ${process.env.REPLICATE_API_TOKEN}`,
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        version: "f5122298c4b8db6b8e0f10c3a3e8f2b7d3f4e5c6d7e8f9a0b1c2d3e4f5a6b7c8",
        input: {
          image: image,
          prompt: "epic oil painting portrait of a pet as renaissance royalty, ornate golden frame, velvet robes, majestic lighting, detailed fur, masterpiece, 8k",
          negative_prompt: "blurry, low quality, cartoon, anime, text, watermark, cropped",
          num_inference_steps: 30,
          guidance_scale: 7.5,
          width: 768,
          height: 1024
        }
      })
    });

    if (!startResponse.ok) {
      const error = await startResponse.text();
      return new Response(JSON.stringify({ error: `Replicate start failed: ${error}` }), {
        status: 500,
        headers: { "Content-Type": "application/json" }
      });
    }

    let prediction = await startResponse.json();
    
    // Poll until done
    while (prediction.status !== "succeeded" && prediction.status !== "failed") {
      await new Promise(r => setTimeout(r, 1000));
      const pollResponse = await fetch(`https://api.replicate.com/v1/predictions/${prediction.id}`, {
        headers: { "Authorization": `Token ${process.env.REPLICATE_API_TOKEN}` }
      });
      prediction = await pollResponse.json();
    }

    if (prediction.status === "failed") {
      return new Response(JSON.stringify({ error: `Generation failed: ${prediction.error}` }), {
        status: 500,
        headers: { "Content-Type": "application/json" }
      });
    }

    return new Response(JSON.stringify({ output: prediction.output }), {
      headers: { "Content-Type": "application/json" }
    });

  } catch (err) {
    return new Response(JSON.stringify({ error: err.message }), {
      status: 500,
      headers: { "Content-Type": "application/json" }
    });
  }
};